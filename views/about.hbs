{{#> app}}
{{#*inline "content"}}

<div style="max-width: 1000px; margin: 40px auto; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; padding: 0 20px;">
    
    <div style="text-align: center; margin-bottom: 60px;">
